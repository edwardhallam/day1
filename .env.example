# ============================================================
# Delivery Tracking Service — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================
# DEPLOY-REQ-048

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=delivery_user
# 1Password: nexus > Delivery Tracking Postgres (field: Password)
POSTGRES_PASSWORD=
POSTGRES_DB=delivery_tracker

# Constructed from the above — update if you change them
DATABASE_URL=postgresql+psycopg://delivery_user:CHANGE_ME@postgres:5432/delivery_tracker

# ── Parcel API ────────────────────────────────────────────────
# Get your API key at https://web.parcelapp.net
# 1Password: nexus > Parcel App API (field: API Key)
PARCEL_API_KEY=

# ── Authentication ────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# 1Password: nexus > Delivery Tracking JWT (field: Secret Key)
JWT_SECRET_KEY=
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=7
# BCRYPT_ROUNDS=12
# COOKIE_SECURE=false
# TRUST_PROXY_HEADERS=true

# ── First-Run Admin Setup ─────────────────────────────────────
# IMPORTANT: Remove ADMIN_PASSWORD from .env after first successful start.
ADMIN_USERNAME=admin
# 1Password: nexus > Delivery Tracking Admin (field: Password)
ADMIN_PASSWORD=

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_HTTP_PORT=80

# ── HTTPS (optional — leave HTTPS_ENABLED=false for HTTP-only) ─
HTTPS_ENABLED=false
# SSL_CERT_PATH=/path/on/host/to/cert.pem
# SSL_KEY_PATH=/path/on/host/to/key.pem

# ── Polling (defaults shown) ──────────────────────────────────
# POLL_INTERVAL_MINUTES=15
# POLL_JITTER_SECONDS=30
# POLL_HTTP_TIMEOUT_SECONDS=30
# POLL_MAX_RETRIES=3

# ── Application ───────────────────────────────────────────────
ENVIRONMENT=production
# LOG_LEVEL=INFO
